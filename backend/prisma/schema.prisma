generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  admin
}

enum TaskStatus {
  draft
  published
  executor_selected
  in_progress
  on_review
  completed
}

enum ResponseStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum NotificationType {
  new_response
  executor_selected
  task_completed
  task_reviewed
  deadline_soon
  comment_reply
  task_published_matching_skills
}

enum ComplaintStatus {
  open
  resolved
  rejected
}

model StudentStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]

  @@map("student_statuses")
}

model User {
  id                  String     @id @default(cuid())
  firstName           String
  lastName            String
  middleName          String?
  email               String     @unique
  passwordHash        String
  registrationDate    DateTime   @default(now())
  avatar              String?
  bio                 String?
  role                UserRole   @default(student)
  studentStatusId     String?
  isBlocked           Boolean    @default(false)
  lastSeenAt          DateTime?
  rating              Decimal    @default(0) @db.Decimal(3, 2)
  completedTasksCount Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  studentStatus StudentStatus? @relation(fields: [studentStatusId], references: [id], onDelete: SetNull)
  skills        StudentSkill[]
  customerTasks Task[]         @relation("CustomerTasks")
  executorTasks Task[]         @relation("ExecutorTasks")
  responses     Response[]
  comments      Comment[]
  reviewsGiven  Review[]       @relation("ReviewsGiven")
  reviewsGot    Review[]       @relation("ReviewsGot")
  notifications Notification[]
  achievements  UserAchievement[]
  complaintsMade Complaint[]   @relation("ComplaintsMade")
  complaintsGot  Complaint[]   @relation("ComplaintsGot")

  @@index([role])
  @@index([isBlocked])
  @@map("users")
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students StudentSkill[]
  tasks    TaskSkill[]

  @@map("skills")
}

model StudentSkill {
  userId  String
  skillId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([skillId])
  @@map("student_skills")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@map("categories")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String
  deadline    DateTime
  status      TaskStatus @default(draft)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customerId String
  executorId String?
  categoryId String

  customer User     @relation("CustomerTasks", fields: [customerId], references: [id], onDelete: Restrict)
  executor User?    @relation("ExecutorTasks", fields: [executorId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  skills        TaskSkill[]
  responses     Response[]
  comments      Comment[]
  review        Review?
  statusHistory TaskStatusHistory[]
  notifications Notification[]
  complaints    Complaint[]

  @@index([status, deadline])
  @@index([categoryId, status])
  @@index([customerId])
  @@index([executorId])
  @@index([deletedAt])
  @@map("tasks")
}

model TaskSkill {
  taskId  String
  skillId String
  addedAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([taskId, skillId])
  @@index([skillId])
  @@map("task_skills")
}

model TaskStatusHistory {
  id          String     @id @default(cuid())
  taskId      String
  fromStatus  TaskStatus?
  toStatus    TaskStatus
  changedById String
  reason      String?
  createdAt   DateTime   @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_status_history")
}

model Response {
  id          String         @id @default(cuid())
  taskId      String
  responderId String
  status      ResponseStatus @default(pending)
  message     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  withdrawnAt DateTime?

  task          Task                    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  responder     User                    @relation(fields: [responderId], references: [id], onDelete: Cascade)
  statusHistory ResponseStatusHistory[]

  @@unique([taskId, responderId])
  @@index([responderId, status])
  @@map("responses")
}

model ResponseStatusHistory {
  id          String          @id @default(cuid())
  responseId  String
  fromStatus  ResponseStatus?
  toStatus    ResponseStatus
  changedById String
  reason      String?
  createdAt   DateTime        @default(now())

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([responseId, createdAt])
  @@map("response_status_history")
}

model Comment {
  id        String    @id @default(cuid())
  taskId    String
  authorId  String
  parentId  String?
  body      String
  isPinned  Boolean   @default(false)
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([taskId, parentId, createdAt])
  @@map("comments")
}

model Review {
  id         String   @id @default(cuid())
  taskId     String   @unique
  reviewerId String
  reviewedId String
  rating     Int
  text       String?
  createdAt  DateTime @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Restrict)
  reviewed User @relation("ReviewsGot", fields: [reviewedId], references: [id], onDelete: Restrict)

  @@index([reviewedId])
  @@map("reviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  taskId    String?
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  createdAt   DateTime @default(now())
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String
  achievementId String
  awardedAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model Complaint {
  id           String          @id @default(cuid())
  taskId       String?
  reporterId   String
  reportedId   String
  reason       String
  status       ComplaintStatus @default(open)
  createdAt    DateTime        @default(now())
  resolvedAt   DateTime?

  task     Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  reporter User  @relation("ComplaintsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User  @relation("ComplaintsGot", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("complaints")
}
